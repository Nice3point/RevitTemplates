<Project Sdk="Nice3point.Revit.Sdk">

    <PropertyGroup>
<!--#if (!isDbApplicationAddin)-->
        <UseWPF>true</UseWPF>
<!--#endif-->
        <DeployAddin>true</DeployAddin>
        <LaunchRevit>true</LaunchRevit>
<!--#if (addinLogging || useDi)-->
        <IsRepackable>true</IsRepackable>
<!--#else-->
        <IsRepackable>false</IsRepackable>
<!--#endif-->
        <EnableDynamicLoading>true</EnableDynamicLoading>
        <Configurations>Debug.R23;Debug.R24;Debug.R25;Debug.R26;Debug.R27</Configurations>
        <Configurations>$(Configurations);Release.R23;Release.R24;Release.R25;Release.R26;Release.R27</Configurations>
        <RootNamespace Condition="'$(name)' != '$(name{-VALUE-FORMS-}safe_namespace)'">Nice3point.Revit.AddIn._1</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <!-- Revit Dependencies -->
        <PackageReference Include="Nice3point.Revit.Toolkit" Version="$(RevitVersion).*"/>
        <PackageReference Include="Nice3point.Revit.Extensions" Version="$(RevitVersion).*"/>
        <PackageReference Include="Nice3point.Revit.Api.RevitAPI" Version="$(RevitVersion).*"/>
<!--#if (!isDbApplicationAddin)-->
        <PackageReference Include="Nice3point.Revit.Api.RevitAPIUI" Version="$(RevitVersion).*"/>
<!--#endif-->
<!--#if (diContainer)-->

        <!-- Application Hosting -->
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.5"/>
<!--#endif-->
<!--#if (diHosting)-->

        <!-- Application Hosting -->
        <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.5"/>
<!--#endif-->
<!--#if (addinLogging)-->

        <!-- Logging -->
        <PackageReference Include="Serilog" Version="4.3.1"/>
        <PackageReference Include="Serilog.Sinks.Debug" Version="3.0.0"/>
<!--#endif-->
<!--#if (addinLogging && diHosting)-->
        <PackageReference Include="Serilog.Extensions.Hosting" Version="10.0.0"/>
<!--#endif-->
<!--#if (addinLogging || useDi)-->

        <!-- Build Automation-->
        <PackageReference Include="ILRepack" Version="2.0.44"/>
<!--#endif-->

        <!-- Development Dependencies -->
        <PackageReference Include="JetBrains.Annotations" Version="2025.2.4" PrivateAssets="all"/>
        <PackageReference Include="Polyfill" Version="10.3.0" PrivateAssets="all"/>
    </ItemGroup>

<!--#if (isApplicationAddin)-->
    <ItemGroup>
        <Resource Include="Resources\Icons\RibbonIcon16.png"/>
        <Resource Include="Resources\Icons\RibbonIcon32.png"/>
    </ItemGroup>

<!--#endif-->
</Project>